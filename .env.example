# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required: PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/dfhc_db

# Required: JWT signing key
# Generate a strong key with: openssl rand -hex 32
# Replace REPLACE_WITH_OUTPUT_OF_OPENSSL_RAND_HEX_32 below with your actual key
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_OPENSSL_RAND_HEX_32

# Optional: JWT expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional: Set to true in CI/testing ONLY. Never set in production.
# TESTING=true
